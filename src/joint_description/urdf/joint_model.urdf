<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="joint_model">

  <!-- include macro file -->
  <xacro:include filename="$(find joint_description)/urdf/joint_model.macro.urdf"/>

  <!-- world link (no prefix) -->
  <link name="world">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- instantiate robot with prefix -->
  <xacro:joint_model prefix="ur1_"/>

  <!-- base_joint (no prefix), but child points to prefixed base_link -->
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="ur1_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>